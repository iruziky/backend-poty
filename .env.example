# --- Postgres ---
POSTGRES_USER=poty
POSTGRES_PASSWORD=poty
POSTGRES_DB=poty
POSTGRES_HOST=db
POSTGRES_PORT=5433

# URL completa usada pelo SQLAlchemy (asyncpg).
# Mantém em sincronia com as variáveis POSTGRES_* acima.
DATABASE_URL=postgresql+asyncpg://poty:poty@db:5432/poty

# --- Auth ---
JWT_SECRET=changeme-super-secret
JWT_EXPIRE_DAYS=7

# --- OpenRouter ---
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4o-mini
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# --- App ---
CORS_ORIGINS=*
TZ=America/Sao_Paulo
